{"metadata":{"authorName":"Aspen Rodriguez"},"content":"\\documentclass[12pt,a4paper]{article}\r\n\\usepackage[utf8]{inputenc}\r\n\\usepackage[margin=1in]{geometry}\r\n\\usepackage{amsmath}\r\n\\usepackage{amsfonts}\r\n\\usepackage{amssymb}\r\n\\usepackage{graphicx}\r\n\\usepackage{mhchem} \\RequirePackage{amsmath,amssymb,latexsym}\r\n\\usepackage{circuitikz}\r\n\\usepackage{subfig}\r\n\\author{Aspen Rodriguez Bloom}\r\n\\title{PyTeX Demo}\r\n\\date{\\today}\r\n\\begin{document}\r\n\\maketitle\r\n\\section{\\LaTeX{} Section}\r\n\\subsection{The Chemistry Library}\r\n\\begin{itemize}\r\n\\item \\ce{ [Cd\\{SC(NH2)2\\}2].[Cr(SCN)4(NH3)2]2 }\r\n\\item \\ce{ A\\bond{~=}B\\bond{~--}C\\bond{-~-}D }\r\n\\end{itemize}\r\n\\subsection{The Electrical Engineering Library}\r\n\\begin{tikzpicture}[scale=2]\r\n  \\draw[color=black, thick]\r\n    (0,0) to [short,o-] (6,0){} % Baseline for connection to ground\r\n    % Input and ground\r\n    (0,1) node[]{\\large{\\textbf{INPUT}}}\r\n    % Connection of passive components\r\n    (5,0) node[ground]{} node[circ](4.5,0){}\r\n    (0,2) to [pC, l=$C_1$, o-] (0.5,2)\r\n    to [R,l=$R_1$,](1.5,2)\r\n    to node[short]{}(2.6,2)\r\n    (1.5,2) to [C, l=$C_2$, *-] (1.5,3) -| (5,3)\r\n    (2.2,2) to [R, l=$R_2$, *-*] (2.2,3)\r\n    (2.2,3) to [pC, l=$C_3$, *-] (2.2,5) -| (3,5)\r\n    % Transistor Bipolar Q1\r\n    (3,0) to [R,l=$R_5$,-*] (3,1.5)\r\n    to [Tnpn,n=npn1] (3,2.5)\r\n    (npn1.E) node[right=3mm, above=5mm]{$Q_1$} % Labelling the NPN transistor\r\n    (4,0) to [pC, l_=$C_4$, *-] (4, 1.5)--(3,1.5)\r\n    (2.2,0) to [vR, l=$R_3$, *-*] (2.2,2)\r\n    (3,2.5) to node[short]{}(3,3)\r\n    (3,5) to [pR, n=pot1, l_=$R_4$, *-] (3,3)\r\n    (3,5) to [R, l=$R_6$, *-] (5,5)\r\n    to [short,*-o](5,5.5) node[right]{$V_S=40 V$}\r\n    % Mosfet Transistors\r\n    (5,3) to [Tnigfetd,n=mos1] (5,5)\r\n    (mos1.B) node[anchor=west]{$Q_2$} % Labelling MOSFET Q2 Transistor\r\n    (pot1.wiper)  to [R, l=$R_7$] (4.5,4) -| (mos1.G)\r\n    (5,1.5) to [Tpigfetd,n=mos2] (5,2.5)\r\n    (5,0) to (mos2.S)\r\n    (3,2.5) to [R, l=$R_8$, *-] (4.5,2.5)\r\n    -| (mos2.G)\r\n    (mos2.B) node[anchor=west]{$Q_3$} % Labelling MOSFET Q3 Transistor\r\n    % Output\r\n    (6,3) to [pC, l=$C_5$,-*](5,3)\r\n    (6,3) to [short,-o] (6,2){}\r\n    (mos1.S)--(mos2.D)\r\n    (6,0) to [short,-o] (6,1){} node[above=7mm]{\\large{\\textbf{SPEAKER}}}\r\n    ;\r\n\\end{tikzpicture}\r\n\\section{The Python Section}\r\n\\subsection{Quadratics}\r\n<py>\r\nimport random\r\nimport math\r\nimport numpy as np\r\ncoefs = np.array([0,0,0])\r\ndef gen():\r\n\tfor i in range(3):\r\n\t\tr = random.randint(-100,100)\r\n\t\tcoefs[i] = r\r\ngen()\r\nwhile (coefs[1]**2)<(4*coefs[0]*coefs[2]):\r\n\tgen()\r\ndef quad(inp):\r\n\ta = inp[0]\r\n\tb = inp[1]\r\n\tc = inp[2]\r\n\tp = (-b+np.sqrt((b**2)-(4*a*c)))/(2*a)\r\n\tm = (-b -np.sqrt((b**2)-(4*a*c)))/(2*a)\r\n\treturn [p,m]\r\nroots = quad(coefs)\t\t\r\nscoefs = []\r\nfor coef, index in zip(coefs, range(0,3)):\r\n\tif coef<0:\r\n\t\tscoefs.append(str(coef))\r\n\telif coef==1:\r\n\t\tscoefs.append(\"\")\r\n\telif coef==-1:\r\n\t\tscoefs.append(\"-\")\r\n\telif index==0:\r\n\t\tscoefs.append(str(coef))\r\n\telse:\r\n\t\tscoefs.append(\"+\" + str(coef))\r\noutp = \"$y=%sx^2%sx%s$ has roots %s and %s\" % (scoefs[0], scoefs[1], scoefs[2], str(roots[0]), str(roots[1]))\r\nprint(outp)\r\n</py>\r\n\\subsection{Graphing} \r\n\\begin{figure}[h]\r\n\\centering\r\n<py>\r\nfrom matplotlib import pyplot as plt\r\nimport os\r\nhomepath = os.path.dirname(os.path.abspath(__file__))\r\nfile1 = \"fig1.png\"\r\nfigpath1 = os.path.join(homepath, file1)\r\nxs=np.array(range(-100,101))\r\nys=np.array([])\r\na=np.float32(coefs[0])\r\nb=np.float32(coefs[1])\r\nc=np.float32(coefs[2])\r\ndef eq(x):\r\n\ty=(a*(x**2))+(b*x)+c\r\n\treturn y\r\nfor x in xs:\r\n\tx = np.float32(x)\r\n\ty=eq(x)\r\n\tys = np.append(ys, y)\r\nfig = plt.figure()\r\nfig1 = fig.add_subplot(1,1,1)\r\nfig1.plot(xs,ys)\r\nplt.savefig(figpath1, dpi=300.)\r\na1=scoefs[0]\r\nb1=scoefs[1]\r\nc1=scoefs[2]\r\nprint(\"\\\\subfloat[\\\\centering A graph of $y=%sx^2%sx%s$]{{\\\\includegraphics[scale=0.45]{\" % (a1,b1,c1)+figpath1+\"}}}\")\r\n</py>\r\n\\qquad\r\n<py>\r\nfigf = plt.figure()\r\nfile2 = \"fig2.png\"\r\nfigpath2 = os.path.join(homepath, file2)\r\nran = []\r\nfor r in roots:\r\n\tval = round(r)\r\n\tif len(ran)>0 and ran[0]>val:\r\n\t\ttemp = ran[0]\r\n\t\tran[0] = val\r\n\t\tran.append(temp)\r\n\telse:\r\n\t\tran.append(val)\r\nxx=np.array(range((ran[0]-2)*100, (ran[1]+2)*100)).astype(np.float64)\r\nfor x, i in zip(xx, range(len(xx))):\r\n\txx[i]=x/100.\r\nyy=np.array([]) \r\nfor x in xx:\r\n\tx = np.float32(x)\r\n\ty=eq(x)\r\n\tyy = np.append(yy, y)\r\ny2 = np.array([eq(roots[0]),eq(roots[1])])\r\nfig2 = figf.add_subplot(1,1,1)\r\nfig2.plot(xx,yy)\r\nfig2.plot(roots, y2, linestyle='none', marker='.', markersize=20.0, color='r')\r\nplt.savefig(figpath2, dpi=300.)\r\nprint(\"\\\\subfloat[\\\\centering A closer view of the roots %s and %s]{{\\\\includegraphics[scale=0.45]{\" % (round(roots[0],4), round(roots[1],4))+figpath2+\"}}}\")\r\n</py>\r\n\\caption{The randomly generated quadratic equation from Section 2.1, graphed.}\r\n\\end{figure}\r\n\\end{document}","id":"20250325-1248-8e58-8861-7eb5f70ff39a"}